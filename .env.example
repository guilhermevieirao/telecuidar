# ==========================
# TeleCuidar - Variáveis de Ambiente
# ==========================

# ===========================
# Docker Compose Configuration
# ===========================

# JWT Configuration (OBRIGATÓRIO em produção)
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-SECRET-KEY-WITH-AT-LEAST-32-CHARACTERS

# Admin User Configuration (para primeiro acesso)
ADMIN_ENABLED=true
ADMIN_EMAIL=adm@adm.com
ADMIN_PASSWORD=zxcasd

# IMPORTANTE:
# 1. Altere JWT_SECRET para uma chave forte e única
# 2. Em produção, defina ADMIN_ENABLED=false após criar o primeiro admin
# 3. Nunca commite o arquivo .env no Git

# ===========================
# Backend (.NET API) - Configurações Avançadas
# ===========================

# Database (SQLite usado no Docker por padrão)
DATABASE_SERVER=(localdb)\\mssqllocaldb
DATABASE_NAME=TeleCuidar
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_TRUST_SERVER_CERTIFICATE=true

# JWT Authentication (valores já definidos acima para Docker)
# JWT_SECRET=sua-chave-secreta-super-segura-aqui-min-32-caracteres
# JWT_ISSUER=TeleCuidar
# JWT_AUDIENCE=TeleCuidar
JWT_EXPIRATION_MINUTES=60

# API Configuration
API_PORT=5058
ASPNETCORE_ENVIRONMENT=Development
CORS_ORIGINS=http://localhost:4200

# Email Service (Futuro)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
SMTP_FROM_EMAIL=noreply@telecuidar.com.br
SMTP_FROM_NAME=TeleCuidar

# Azure Storage (Futuro - para uploads)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=telecuidar-uploads

# ===========================
# Frontend (Angular)
# ===========================

# API URLs
NG_APP_API_URL=http://localhost:5058/api
NG_APP_API_TIMEOUT=30000

# Features Flags
NG_APP_ENABLE_DEBUG=true
NG_APP_ENABLE_ANALYTICS=false

# External Services (Futuro)
NG_APP_GOOGLE_ANALYTICS_ID=
NG_APP_SENTRY_DSN=

# ===========================
# WebRTC / Videochamada
# ===========================
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=

# ===========================
# Logs & Monitoring
# ===========================
LOG_LEVEL=Information
ENABLE_SWAGGER=true
ENABLE_DETAILED_ERRORS=true

# ===========================
# Segurança
# ===========================
ENABLE_HTTPS_REDIRECT=false
ENABLE_HSTS=false
MAX_REQUEST_SIZE_MB=10
RATE_LIMIT_REQUESTS_PER_MINUTE=100
