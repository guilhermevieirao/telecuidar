# ==========================
# TeleCuidar - Environment Variables Example
# ==========================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Database
ConnectionStrings__DefaultConnection=Data Source=telecuidar.db

# JWT Configuration
Jwt__Secret=your-super-secret-jwt-key-change-this-in-production-min-32-chars
Jwt__Issuer=TeleCuidar
Jwt__Audience=TeleCuidar-Users
Jwt__ExpirationHours=24

# Admin User (for initial seed - disable in production)
AdminUser__Email=adm@adm.com
AdminUser__Password=ChangeThisPassword123!
AdminUser__FirstName=Administrador
AdminUser__LastName=Sistema
AdminUser__Enabled=true

# Email Service (TODO: Configure with real SMTP/SendGrid/AWS SES)
Email__Provider=Console
Email__FromAddress=noreply@telecuidar.com
Email__FromName=TeleCuidar

# Application Settings
AllowedHosts=*
ASPNETCORE_ENVIRONMENT=Development
