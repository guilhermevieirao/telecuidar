# ==========================
# TeleCuidar - Environment Variables Example
# ==========================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ===========================
# Database
# ===========================
ConnectionStrings__DefaultConnection=Data Source=telecuidar.db

# ===========================
# JWT Configuration
# ===========================
Jwt__Secret=your-super-secret-jwt-key-change-this-in-production-min-32-chars
Jwt__Issuer=TeleCuidar
Jwt__Audience=TeleCuidar-Users
Jwt__ExpirationHours=24

# ===========================
# Admin User (for initial seed)
# ===========================
AdminUser__Email=adm@adm.com
AdminUser__Password=admadm
AdminUser__FirstName=adm
AdminUser__LastName=adm
AdminUser__Enabled=true

# IMPORTANTE: Em produção, defina AdminUser__Enabled=false após criar o primeiro admin

# ===========================
# DeepSeek AI Configuration
# ===========================
DeepSeek__ApiKey=sk-your-deepseek-api-key-here
DeepSeek__ApiUrl=https://api.deepseek.com/v1/chat/completions

# ===========================
# Email Service - SMTP Configuration
# ===========================
Email__SmtpHost=smtp.example.com
Email__SmtpPort=587
Email__SmtpUsername=your-email@example.com
Email__SmtpPassword=your-password-here
Email__FromEmail=noreply@telecuidar.com
Email__FromName=Telecuidar
Email__EnableSsl=true

# ===========================
# Application Settings
# ===========================
AllowedHosts=*
ASPNETCORE_ENVIRONMENT=Development
FrontendUrl=http://localhost:4200

# ===========================
# API Configuration
# ===========================
API_PORT=5058
CORS_ORIGINS=http://localhost:4200

# ===========================
# Logs & Monitoring
# ===========================
LOG_LEVEL=Information
ENABLE_SWAGGER=true
ENABLE_DETAILED_ERRORS=true

# ===========================
# Segurança
# ===========================
ENABLE_HTTPS_REDIRECT=false
ENABLE_HSTS=false
MAX_REQUEST_SIZE_MB=10
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ===========================
# WebRTC / Videochamada (Futuro)
# ===========================
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=

# ===========================
# Azure Storage (Futuro - para uploads)
# ===========================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=telecuidar-uploads

# ===========================
# CADSUS Configuration (Ministério da Saúde)
# ===========================
# Sistema de Consulta ao Cadastro Nacional de Usuários do SUS
# Requer certificado digital A1 (.pfx) válido

# Ambiente: 'producao' ou 'hmg' (homologação)
CADSUS__Ambiente=producao

# URLs de Autenticação (NÃO ALTERAR)
CADSUS__AuthUrl_Hmg=https://ehr-auth-hmg.saude.gov.br/api/osb/token
CADSUS__AuthUrl_Prod=https://ehr-auth.saude.gov.br/api/osb/token

# URLs de Consulta v2 com JWT (NÃO ALTERAR)
CADSUS__QueryUrl_Hmg=https://servicoshm.saude.gov.br/cadsus/v2/PDQSupplierJWT
CADSUS__QueryUrl_Prod=https://servicos.saude.gov.br/cadsus/v2/PDQSupplierJWT

# Caminho do Certificado Digital A1 (.pfx)
# Windows: use barras duplas (\\) ou barras simples (/)
# Exemplo: C:\\certificados\\cert.pfx ou C:/certificados/cert.pfx
CADSUS__CertPath=C:\\certificados\\certificado.pfx

# Senha do Certificado Digital
CADSUS__CertPassword=senha-do-certificado-aqui

# ATENÇÃO:
# - O certificado deve ser A1 (.pfx) válido
# - Deve ter permissão para acessar o CADSUS
# - Nunca commit o arquivo .env com dados reais
# - Tokens JWT expiram em 30 minutos e são renovados automaticamente

# ===========================
# External Services (Futuro)
# ===========================
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=
