# ==========================
# TeleCuidar - Environment Variables Example
# ==========================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Database
ConnectionStrings__DefaultConnection=Data Source=telecuidar.db

# JWT Configuration
Jwt__Secret=your-super-secret-jwt-key-change-this-in-production-min-32-chars
Jwt__Issuer=TeleCuidar
Jwt__Audience=TeleCuidar-Users
Jwt__ExpirationHours=24

# Admin User (for initial seed - disable in production)
AdminUser__Email=adm@adm.com
AdminUser__Password=admadm
AdminUser__FirstName=adm
AdminUser__LastName=adm
AdminUser__Enabled=true

# Email Service - SMTP Configuration
Email__SmtpHost=smtp.example.com
Email__SmtpPort=587
Email__SmtpUsername=your-email@example.com
Email__SmtpPassword=your-password-here
Email__FromEmail=noreply@telecuidar.com
Email__FromName=Telecuidar
Email__EnableSsl=true

# Application Settings
AllowedHosts=*
ASPNETCORE_ENVIRONMENT=Development
